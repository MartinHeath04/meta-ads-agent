# Sea Street Detailing Meta Ads Agent - Environment Variables
# Copy this file to .env and fill in your values

# ======================
# Meta API Credentials
# ======================
# Get these from Meta Business Suite / Developer Portal
META_ACCESS_TOKEN=your_access_token_here
META_AD_ACCOUNT_ID=act_123456789
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret

# ======================
# Anthropic API (Agent Brain)
# ======================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ======================
# Email (Daily Reports)
# ======================
# For Gmail: use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_TO=your_email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# ======================
# Database Configuration
# ======================
DATABASE_PATH=./data/sea_street.db

# ======================
# Logging
# ======================
LOG_LEVEL=INFO
LOG_DIR=./data/logs

# ======================
# Reports
# ======================
REPORT_OUTPUT_DIR=./data/exports

# ======================
# Feature Flags
# ======================
# Set to true to enable automatic actions (pause ads, reduce budget)
ENABLE_AUTO_ACTIONS=false

# Set to true to simulate actions without making actual API calls
DRY_RUN_MODE=true
